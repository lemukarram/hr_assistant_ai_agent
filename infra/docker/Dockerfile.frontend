# ── Frontend Dockerfile ─────────────────────────────────────────────────────
# Build context: ./frontend  (set in docker-compose.yml)
# ──────────────────────────────────────────────────────────────────────────

FROM node:20-alpine AS base

WORKDIR /app
COPY package*.json .
RUN npm install

# ── Development (hot-reload, source bind-mounted) ──────────────────────────
FROM base AS development

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

# ── Build stage ────────────────────────────────────────────────────────────
FROM base AS builder

COPY . .

ARG VITE_API_URL=/api
ENV VITE_API_URL=$VITE_API_URL

RUN npm run build

# ── Production — serve with Nginx ─────────────────────────────────────────
FROM nginx:1.25-alpine AS production

# Copy the built SPA
COPY --from=builder /app/dist /usr/share/nginx/html

# Nginx config is mounted from host via docker-compose, no COPY needed.
# If running standalone without a compose mount, uncomment the line below:
# COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
    CMD wget -qO- http://localhost:80/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
