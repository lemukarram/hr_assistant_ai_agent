# ─────────────────────────────────────────────────────────────────────────────
#  HR Assistant — Environment Configuration
#  Copy this file to .env and review all values before running.
#  For local demo, defaults work out of the box — no secret setup required.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development    # development | production
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=dev_secret_key_replace_in_production_minimum_32_characters_required

# JWT settings
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hrdb
POSTGRES_USER=hruser
POSTGRES_PASSWORD=hrpass_change_in_production
# Full DSN (auto-built from above in Docker Compose)
# DATABASE_URL=postgresql://hruser:hrpass@postgres:5432/hrdb

# ── Vector Store ─────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=hr_handbook

# ── LLM — OpenAI-compatible endpoint (locally deployed) ──────────────────────
# Supports any OpenAI-compatible server: LiteLLM proxy, vLLM, Ollama, etc.
LLM_BASE_URL=http://your-llm-proxy:4000/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemini-3.1-flash-lite

# Model parameters
LLM_TEMPERATURE=0.1          # Low for factual HR answers
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=8192

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3  # Downloaded on first run, cached in Docker volume
EMBEDDING_DEVICE=cpu          # cpu | cuda | mps
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── RAG Pipeline ─────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K_RETRIEVE=10       # Candidates before reranking
RAG_TOP_K_RERANK=3          # Final chunks sent to LLM
RAG_HANDBOOK_DIR=/app/data/handbook

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://mcp-server:8001
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=مساعد الموارد البشرية
VITE_DEFAULT_LANGUAGE=ar

# ── Observability ────────────────────────────────────────────────────────────
ENABLE_AUDIT_LOG=true
ENABLE_METRICS=true
METRICS_PORT=9090
